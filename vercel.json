{
    "redirects": [{
        "source": "/vendor/:path*",
        "destination": "/vendor/:path*",
        "permanent": false
    },
    {
        "source": "/fonts/:path*",
        "destination": "/fonts/:path*",
        "permanent": false
    },
    {
        "source": "/:namespace/:article",
        "destination": "/?namespace=:namespace&article=:article",
        "permanent": false
    }]
}